  `that HMO or house is occupied by more than the maximum number of households or persons specified in the licence`  IS FALSE
  `compliance with a planning enforcement notice or injunction would be or is incompatible with continued occupation by the tenant`  IS FALSE

#ASSERT NOT `(b) — improvement notice for overcrowding` `claim via (b) — no overcrowding`
#ASSERT NOT `Ground 6B made out`                        `claim via (b) — no overcrowding`

